# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PERSISTENT GOOGLE INTEGRATIONS (VERSION 1)
# ------------------------------------------
# To guarantee no client inquiries are lost upon container redeployment, 
# configure these variables to store submissions directly in Google Sheets or Google Forms.

# 1. Google Sheets Webhook URL (Recommended)
# Fill this with the Web App URL generated from the Google Apps Script of your spreadsheet
GOOGLE_SHEETS_WEBHOOK_URL="https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec"

# 2. Google Forms Response Submission URL (Alternative)
# Fill this with the direct 'formResponse' post destination URL of your public Google Form
GOOGLE_FORM_RESPONSE_URL="https://docs.google.com/forms/d/e/YOUR_FORM_ID/formResponse"

# Custom entry.XXXX IDs map fields to Google Forms columns.
# See detailed guidelines on using your Browser Inspector to find these IDs.
GOOGLE_FORM_FIELD_NAME="entry.20001"
GOOGLE_FORM_FIELD_EMAIL="entry.20002"
GOOGLE_FORM_FIELD_EXPERIENCE="entry.20003"
GOOGLE_FORM_FIELD_BUDGET="entry.20004"
GOOGLE_FORM_FIELD_DATE="entry.20005"
GOOGLE_FORM_FIELD_DESC="entry.20006"

# STRIPE INTEGRATION (SECURE PAYMENTS)
# Server-side Secret Key (keep hidden from frontend)
STRIPE_SECRET_KEY=""
# Client-side Publishable Key (exposed to frontend)
VITE_STRIPE_PUBLISHABLE_KEY=""

# PAYPAL INTEGRATION (SECURE PAYMENTS)
# Server-side Client ID and Secret (keep hidden from frontend)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# Environment mode: sandbox or live
PAYPAL_ENV="sandbox"
# Client-side Client ID (exposed to frontend)
VITE_PAYPAL_CLIENT_ID=""
